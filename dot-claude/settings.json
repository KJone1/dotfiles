{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(git checkout master && git pull && git diff && git status)",
      "Bash(git log *)",
      "Bash(git rev-list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",
      "Bash(gh search code *)",
      "Bash(gh api repos/*/*/commits/* *)",
      "Bash(gh api repos/*/*/compare/* *)",
      "Bash(gh api repos/*/*/contents/* *)",
      "Bash(gh api repos/*/*/issues *)",
      "Bash(gh api repos/*/*/issues/* *)",
      "Bash(gh api repos/*/*/releases*)",
      "Bash(gh api repos/*/*/tags *)",
      "Bash(kubectl config *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl explain *)",
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(helm lint *)",
      "Bash(helm show values *)",
      "Bash(helm template *)",
      "Bash(gcloud logging read *)",
      "Bash(fastmcp *)",
      "Bash(gemini *)",
      "Bash(just *)",
      "Bash(krr *)",
      "mcp__grafana-prod",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-sonnet-4-6[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "prefersReducedMotion": true,
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
