{
  "git_panel": {
    "dock": "left",
    "button": true,
    "status_style": "label_color",
    "collapse_untracked_diff": false,
    "tree_view": true,
    "fallback_branch_name": "master",
  },
  "diff_view_style": "split",
  "notification_panel": {
    "button": false,
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tabs": {
    "file_icons": false,
    "git_status": false,
  },
  "tab_bar": {
    "show": false,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
    "show_user_menu": true,
    "show_sign_in": false,
    "show_onboarding_banner": true,
    "show_branch_icon": true,
  },
  "colorize_brackets": true,
  "show_whitespaces": "selection",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
  },
  "tab_size": 2,
  "toolbar": {
    "agent_review": false,
    "code_actions": false,
    "selections_menu": true,
    "quick_actions": true,
    "breadcrumbs": true,
  },
  "minimap": {
    "show": "never",
    "thumb": "hover",
  },
  "gutter": {
    "breakpoints": false,
  },
  "relative_line_numbers": "disabled",
  "debugger": {
    "button": false,
    "save_breakpoints": false,
  },
  "ui_font_family": "JetBrainsMono Nerd Font Mono",
  "collaboration_panel": {
    "button": false,
  },
  "disable_ai": true,
  "session": {
    "trust_all_worktrees": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": true,
    "toml": true,
    "xml": true,
    "lua": true,
    "just": true,
    "git-firefly": true,
    "catppuccin-icons": true,
    "csv": true,
    "raindbow-csv": true,
  },
  "file_scan_exclusions": [
    ".ruff_cache",
    ".mypy_cache",
    ".pytest_cache",
    "__pycache__",
    ".DS_Store",
    ".git",
  ],
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
      "**/values*.yaml",
    ],
    "JSONC": [
      "**/.zed/**/*.json",
      "**/zed/**/*.json",
      "**/Zed/**/*.json",
      "**/.vscode/**/*.json",
    ],
    "Shell Script": [".env.*"],
    "Dockerfile": ["Dockerfile*"],
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": "One Light",
}
